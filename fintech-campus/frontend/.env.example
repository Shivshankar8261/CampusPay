# Optional: call API directly (cross-origin). Leave unset to use Next.js proxy → API_ORIGIN in next.config.
# NEXT_PUBLIC_API_BASE=https://your-api.example.com

# Used by next.config.mjs rewrites (server-side). Browser uses same-origin /api when NEXT_PUBLIC_API_BASE is unset.
API_ORIGIN=http://127.0.0.1:4000
